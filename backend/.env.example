NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/construction_erp"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Company Info (for PDF invoices)
COMPANY_NAME=Orchid Construction Pvt. Ltd.
COMPANY_ADDRESS=123, Business Park, Mumbai - 400001
COMPANY_PHONE=+91-9876543210
COMPANY_EMAIL=info@orchidconstruction.com
COMPANY_GST=27AABCU9603R1ZX

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:5173
