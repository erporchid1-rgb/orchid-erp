generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS & AUTH
// Roles: ADMIN | MD | EXE_DIRECTOR | PRESIDENT_PROJECTS | CFO | GM_PURCHASE
//        PURCHASE_HOD | USER_HOD | INCHARGE | STORE_MANAGER | FINANCE
//        ACCOUNTANT | SITE_ENGINEER
// ─────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  mobile      String?
  password    String
  role        String    @default("SITE_ENGINEER")
  department  String?
  status      String    @default("ACTIVE")
  avatar      String?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  purchases         Purchase[]      @relation("PurchaseCreatedBy")
  purchasesApproved Purchase[]      @relation("PurchaseApprovedBy")
  issuesCreated     StockIssue[]    @relation("IssueCreatedBy")
  issuesApproved    StockIssue[]    @relation("IssueApprovedBy")
  transfersCreated  StockTransfer[] @relation("TransferCreatedBy")
  notifications     Notification[]
  indentsRequested  Indent[]        @relation("IndentRequestedBy")
  indentsHodBy      Indent[]        @relation("IndentHodApprovedBy")
  indentsPurchaseBy Indent[]        @relation("IndentPurchaseApprovedBy")

  csCreated             ComparativeStatement[] @relation("CSCreatedBy")
  csHodRecommended      ComparativeStatement[] @relation("CSHodRecommendedBy")
  csUserVerified        ComparativeStatement[] @relation("CSUserVerifiedBy")
  csPresidentVerified   ComparativeStatement[] @relation("CSPresidentVerifiedBy")

  nfaCreated         NFA[] @relation("NFACreatedBy")
  nfaGmSigned        NFA[] @relation("NFAGmSignedBy")
  nfaUserSigned      NFA[] @relation("NFAUserSignedBy")
  nfaCfoSigned       NFA[] @relation("NFACfoSignedBy")
  nfaPresidentSigned NFA[] @relation("NFAPresidentSignedBy")
  nfaDirSigned       NFA[] @relation("NFADirSignedBy")
  nfaMdApproved      NFA[] @relation("NFAMdApprovedBy")
  nfaMdRecorded      NFA[] @relation("NFAMdRecordedBy")

  mrnCreated          MRN[] @relation("MRNCreatedBy")
  mrnStoreVerified    MRN[] @relation("MRNStoreVerifiedBy")
  mrnPurchaseVerified MRN[] @relation("MRNPurchaseVerifiedBy")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// PROJECTS & SITES
// ─────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  projectName String
  projectType String    @default("THREE_BHK")
  location    String
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("PLANNING")
  budget      Float?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  sites          Site[]
  purchases      Purchase[]
  stockIssues    StockIssue[]
  transfersFrom  StockTransfer[] @relation("TransferFromProject")
  transfersTo    StockTransfer[] @relation("TransferToProject")
  stockMovements StockMovement[]
  indents        Indent[]

  @@map("projects")
}

model Site {
  id          String    @id @default(uuid())
  siteName    String
  projectId   String
  description String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project        Project         @relation(fields: [projectId], references: [id])
  purchases      Purchase[]
  stockIssues    StockIssue[]
  stockMovements StockMovement[]
  transfersFrom  StockTransfer[] @relation("TransferFromSite")
  transfersTo    StockTransfer[] @relation("TransferToSite")
  indents        Indent[]

  @@map("sites")
}

// ─────────────────────────────────────────
// MATERIAL MASTER
// ─────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  materials Material[]

  @@map("categories")
}

model Material {
  id           String    @id @default(uuid())
  materialName String
  categoryId   String
  unit         String
  minimumStock Float     @default(0)
  description  String?
  hsnCode      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  category      Category            @relation(fields: [categoryId], references: [id])
  purchaseItems PurchaseItem[]
  stockMovements StockMovement[]
  issueItems    StockIssueItem[]
  transferItems StockTransferItem[]
  indentItems   IndentItem[]
  csItems       CSItem[]
  mrnItems      MRNItem[]

  @@map("materials")
}

// ─────────────────────────────────────────
// SUPPLIERS / VENDORS
// ─────────────────────────────────────────

model Supplier {
  id           String    @id @default(uuid())
  supplierName String
  mobile       String
  email        String?
  address      String?
  gstNumber    String?
  panNumber    String?
  bankAccount  String?
  bankIfsc     String?
  bankName     String?
  // KYC documents
  panFile      String?
  gstFile      String?
  chequeFile   String?
  msmeFile     String?
  otherKycFile String?
  kycStatus    String    @default("PENDING")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  purchases    Purchase[]
  csQuotations CSQuotation[]
  nfas         NFA[]         @relation("NFASelectedSupplier")

  @@map("suppliers")
}

// ─────────────────────────────────────────
// INDENTS / REQUISITIONS
// Status flow:
//   DRAFT
//   → HOD_PENDING      (submitted to HOD of User Dept)
//   → HOD_APPROVED / HOD_REJECTED / HOD_HOLD
//   → PURCHASE_PENDING (forwarded to Purchase HOD)
//   → PURCHASE_ACCEPTED / PURCHASE_RETURNED / PURCHASE_HOLD
//   → COMPARATIVE      (comparative statement in progress)
//   → NFA              (NFA in progress)
//   → PO_CREATED       (PO placed)
//   → CLOSED
// ─────────────────────────────────────────

model Indent {
  id             String    @id @default(uuid())
  indentNumber   String    @unique
  indentDate     DateTime  @default(now())
  projectId      String?
  siteId         String?
  requestedById  String
  category       String?   // Civil / MEP / HK
  department     String?   // Engg / Finance / Marketing / IT / HR
  requiredDate   DateTime
  purpose        String?
  remarks        String?
  storeSignature String?
  inchargeSignature String?

  // Level-1: HOD of User Dept
  status              String    @default("DRAFT")
  hodApprovedById     String?
  hodApprovalNotes    String?
  hodApprovalDate     DateTime?
  hodHoldReason       String?

  // Level-2: Purchase HOD
  purchaseApprovedById  String?
  purchaseApprovalNotes String?
  purchaseApprovalDate  DateTime?
  purchaseHoldReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project          Project?      @relation(fields: [projectId], references: [id])
  site             Site?         @relation(fields: [siteId], references: [id])
  requestedBy      User          @relation("IndentRequestedBy", fields: [requestedById], references: [id])
  hodApprovedBy    User?         @relation("IndentHodApprovedBy", fields: [hodApprovedById], references: [id])
  purchaseApprovedBy User?       @relation("IndentPurchaseApprovedBy", fields: [purchaseApprovedById], references: [id])
  items            IndentItem[]
  purchases        Purchase[]
  comparativeStatements ComparativeStatement[]
  nfas             NFA[]

  @@map("indents")
}

model IndentItem {
  id                String   @id @default(uuid())
  indentId          String
  materialId        String
  requestedQty      Float
  unit              String
  makeSpecifications String?
  lastPurchaseFrom  String?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  indent   Indent   @relation(fields: [indentId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@map("indent_items")
}

// ─────────────────────────────────────────
// COMPARATIVE STATEMENT
// Status flow:
//   DRAFT → HOD_RECOMMENDED → USER_VERIFIED → FINAL_VERIFIED
// ─────────────────────────────────────────

model ComparativeStatement {
  id          String    @id @default(uuid())
  csNumber    String    @unique
  indentId    String
  createdById String
  poWithoutCS Boolean   @default(false)
  notes       String?
  status      String    @default("DRAFT")

  hodRecommendedById  String?
  hodRecommendedAt    DateTime?
  hodNotes            String?

  userVerifiedById    String?
  userVerifiedAt      DateTime?
  userNotes           String?

  presidentVerifiedById String?
  presidentVerifiedAt   DateTime?
  presidentNotes        String?

  selectedSupplierId  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  indent              Indent       @relation(fields: [indentId], references: [id])
  createdBy           User         @relation("CSCreatedBy", fields: [createdById], references: [id])
  hodRecommendedBy    User?        @relation("CSHodRecommendedBy", fields: [hodRecommendedById], references: [id])
  userVerifiedBy      User?        @relation("CSUserVerifiedBy", fields: [userVerifiedById], references: [id])
  presidentVerifiedBy User?        @relation("CSPresidentVerifiedBy", fields: [presidentVerifiedById], references: [id])
  quotations          CSQuotation[]
  items               CSItem[]
  nfas                NFA[]

  @@map("comparative_statements")
}

model CSQuotation {
  id             String    @id @default(uuid())
  csId           String
  supplierId     String
  quotationFile  String?
  quotationDate  DateTime?
  totalAmount    Float?
  remarks        String?
  isSelected     Boolean   @default(false)
  createdAt      DateTime  @default(now())

  cs       ComparativeStatement @relation(fields: [csId], references: [id], onDelete: Cascade)
  supplier Supplier             @relation(fields: [supplierId], references: [id])

  @@map("cs_quotations")
}

model CSItem {
  id           String   @id @default(uuid())
  csId         String
  materialId   String
  qty          Float
  unit         String
  supplier1Rate Float?
  supplier2Rate Float?
  supplier3Rate Float?
  selectedRate  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cs       ComparativeStatement @relation(fields: [csId], references: [id], onDelete: Cascade)
  material Material             @relation(fields: [materialId], references: [id])

  @@map("cs_items")
}

// ─────────────────────────────────────────
// NFA — NOTE FOR APPROVAL (& Draft PO)
// Status flow:
//   DRAFT → GM_SIGNED → USER_SIGNED → CFO_SIGNED
//         → PRESIDENT_SIGNED → DIR_SIGNED
//         → MD_APPROVED / MD_REJECTED / MD_HOLD
// ─────────────────────────────────────────

model NFA {
  id                 String    @id @default(uuid())
  nfaNumber          String    @unique
  indentId           String
  csId               String?
  selectedSupplierId String?
  totalAmount        Float     @default(0)
  paymentTerms       String?
  advancePercent     Float?
  draftPOFile        String?
  notes              String?

  // NFA memo fields — matching physical "Note for Approval" format
  memoType           String?   @default("PO_MEMO")  // PO_MEMO | SITC | AMC | CAMC | SPO
  areaOfUse          String?
  make               String?
  natureOfWork       String?
  productDescription String?
  itemDescription    String?
  baseAmount         Float     @default(0)
  cartage            String?
  gstPercent         Float?
  gstAmount          Float     @default(0)
  modeOfPayment      String?
  lastPurchased      String?
  quotationDate      DateTime?
  comparativeDate    DateTime?

  status             String    @default("DRAFT")
  createdById        String

  gmSignedById        String?
  gmSignedAt          DateTime?
  gmSignature         String?

  userSignedById      String?
  userSignedAt        DateTime?
  userSignature       String?

  cfoSignedById       String?
  cfoSignedAt         DateTime?
  cfoSignature        String?

  presidentSignedById String?
  presidentSignedAt   DateTime?
  presidentSignature  String?

  dirSignedById       String?
  dirSignedAt         DateTime?
  dirSignature        String?

  mdApprovedById      String?
  mdApprovedAt        DateTime?
  mdNotes             String?
  mdSignature         String?
  mdApprovalMode      String?   // DIGITAL | HARD_COPY | PHONE_CALL
  mdRecordedById      String?   // purchase role who recorded physical/call approval

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  indent             Indent                @relation(fields: [indentId], references: [id])
  cs                 ComparativeStatement? @relation(fields: [csId], references: [id])
  selectedSupplier   Supplier?             @relation("NFASelectedSupplier", fields: [selectedSupplierId], references: [id])
  createdBy          User                  @relation("NFACreatedBy", fields: [createdById], references: [id])
  gmSignedBy         User?                 @relation("NFAGmSignedBy", fields: [gmSignedById], references: [id])
  userSignedBy       User?                 @relation("NFAUserSignedBy", fields: [userSignedById], references: [id])
  cfoSignedBy        User?                 @relation("NFACfoSignedBy", fields: [cfoSignedById], references: [id])
  presidentSignedBy  User?                 @relation("NFAPresidentSignedBy", fields: [presidentSignedById], references: [id])
  dirSignedBy        User?                 @relation("NFADirSignedBy", fields: [dirSignedById], references: [id])
  mdApprovedBy       User?                 @relation("NFAMdApprovedBy", fields: [mdApprovedById], references: [id])
  mdRecordedBy       User?                 @relation("NFAMdRecordedBy", fields: [mdRecordedById], references: [id])
  purchases          Purchase[]

  @@map("nfas")
}

// ─────────────────────────────────────────
// PURCHASES / PURCHASE ORDERS
// poType: PO | SPO | WO | ARC
// Statuses: DRAFT → PENDING_APPROVAL → APPROVED/REJECTED → CONFIRMED → RECEIVED → CLOSED
// ─────────────────────────────────────────

model Purchase {
  id                String    @id @default(uuid())
  billNo            String    @unique
  poType            String    @default("PO")
  supplierId        String
  projectId         String?
  siteId            String?
  indentId          String?
  nfaId             String?
  purchaseDate      DateTime
  deliveryDate      DateTime?
  receivedDate      DateTime?
  transportCost     Float     @default(0)
  discountAmount    Float     @default(0)
  gstAmount         Float     @default(0)
  subtotal          Float     @default(0)
  totalAmount       Float     @default(0)
  paidAmount        Float     @default(0)
  paymentTerms      String?
  advancePercent    Float?
  termsConditions   String?
  invoiceFile       String?
  quotation1File    String?
  quotation2File    String?
  quotation3File    String?
  selectedQuotation Int?
  approvedById      String?
  approvalNotes     String?
  notes             String?
  refInvoiceNo      String?
  refInvoiceDate    DateTime?
  attnPerson        String?
  attnMobile        String?
  contactPerson     String?
  contactMobile     String?
  status            String    @default("DRAFT")
  orderedById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  project        Project?       @relation(fields: [projectId], references: [id])
  site           Site?          @relation(fields: [siteId], references: [id])
  indent         Indent?        @relation(fields: [indentId], references: [id])
  nfa            NFA?           @relation(fields: [nfaId], references: [id])
  orderedBy      User           @relation("PurchaseCreatedBy", fields: [orderedById], references: [id])
  approvedBy     User?          @relation("PurchaseApprovedBy", fields: [approvedById], references: [id])
  items          PurchaseItem[]
  stockMovements StockMovement[]
  mrns           MRN[]

  @@map("purchases")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  materialId String
  quantity   Float
  unit       String
  rate       Float
  gstPercent Float    @default(0)
  gstAmount  Float    @default(0)
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@map("purchase_items")
}

// ─────────────────────────────────────────
// MRN — MATERIALS RECEIVING NOTE
// receiptType: PURCHASE | GATE_PASS | NRGP | SITE_TRANSFER
// status: DRAFT → COMPLETE | PARTIAL | EXCESS | RATE_DIFF
// ─────────────────────────────────────────

model MRN {
  id              String    @id @default(uuid())
  mrnNumber       String    @unique
  purchaseId      String?
  receiptType     String    @default("PURCHASE")
  mrnDate         DateTime
  vehicleDetails  String?
  invoiceDate     DateTime?
  invoiceNo       String?
  ewayBillNo      String?
  status          String    @default("DRAFT")
  remarks         String?
  createdById     String

  storeVerifiedById    String?
  storeVerifiedAt      DateTime?
  storeSignature       String?

  userVerifiedById     String?
  userVerifiedAt       DateTime?
  userSignature        String?

  purchaseHodVerifiedById String?
  purchaseHodVerifiedAt   DateTime?

  forwardedToFinance  Boolean  @default(false)
  poClosed            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  purchase             Purchase?     @relation(fields: [purchaseId], references: [id])
  createdBy            User          @relation("MRNCreatedBy", fields: [createdById], references: [id])
  storeVerifiedBy      User?         @relation("MRNStoreVerifiedBy", fields: [storeVerifiedById], references: [id])
  purchaseHodVerifiedBy User?        @relation("MRNPurchaseVerifiedBy", fields: [purchaseHodVerifiedById], references: [id])
  items                MRNItem[]
  documents            MRNDocument[]

  @@map("mrns")
}

model MRNItem {
  id           String   @id @default(uuid())
  mrnId        String
  materialId   String
  poQty        Float
  receivedQty  Float
  rejectedQty  Float    @default(0)
  unit         String
  poRate       Float    @default(0)
  receivedRate Float?
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mrn      MRN      @relation(fields: [mrnId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@map("mrn_items")
}

model MRNDocument {
  id         String   @id @default(uuid())
  mrnId      String
  docType    String   // INVOICE | CN | WEIGHT_SLIP | MTC | BILTY | OTHER
  fileName   String
  uploadedAt DateTime @default(now())

  mrn MRN @relation(fields: [mrnId], references: [id], onDelete: Cascade)

  @@map("mrn_documents")
}

// ─────────────────────────────────────────
// STOCK LEDGER
// ─────────────────────────────────────────

model StockMovement {
  id            String   @id @default(uuid())
  materialId    String
  projectId     String?
  siteId        String?
  movementType  String
  quantity      Float
  balanceAfter  Float
  unit          String
  rate          Float?
  referenceId   String?
  referenceType String?
  purchaseId    String?
  issueId       String?
  transferId    String?
  mrnId         String?
  remarks       String?
  movementDate  DateTime @default(now())
  createdAt     DateTime @default(now())

  material Material  @relation(fields: [materialId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])
  site     Site?     @relation(fields: [siteId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([materialId, siteId])
  @@index([materialId, projectId])
  @@index([movementDate])
  @@map("stock_movements")
}

// ─────────────────────────────────────────
// STOCK ISSUES
// ─────────────────────────────────────────

model StockIssue {
  id           String   @id @default(uuid())
  issueNumber  String   @unique
  projectId    String?
  siteId       String?
  issueDate    DateTime
  issuedTo     String
  issuedById   String
  approvedById String?
  purpose      String?
  status       String   @default("PENDING")
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project?         @relation(fields: [projectId], references: [id])
  site       Site?            @relation(fields: [siteId], references: [id])
  issuedBy   User             @relation("IssueCreatedBy", fields: [issuedById], references: [id])
  approvedBy User?            @relation("IssueApprovedBy", fields: [approvedById], references: [id])
  items      StockIssueItem[]

  @@map("stock_issues")
}

model StockIssueItem {
  id         String   @id @default(uuid())
  issueId    String
  materialId String
  quantity   Float
  unit       String
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  issue    StockIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  material Material   @relation(fields: [materialId], references: [id])

  @@map("stock_issue_items")
}

// ─────────────────────────────────────────
// STOCK TRANSFERS
// ─────────────────────────────────────────

model StockTransfer {
  id             String   @id @default(uuid())
  transferNumber String   @unique
  fromProjectId  String?
  fromSiteId     String?
  toProjectId    String?
  toSiteId       String?
  transferDate   DateTime
  status         String   @default("PENDING")
  createdById    String
  reason         String?
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fromProject Project?            @relation("TransferFromProject", fields: [fromProjectId], references: [id])
  fromSite    Site?               @relation("TransferFromSite", fields: [fromSiteId], references: [id])
  toProject   Project?            @relation("TransferToProject", fields: [toProjectId], references: [id])
  toSite      Site?               @relation("TransferToSite", fields: [toSiteId], references: [id])
  createdBy   User                @relation("TransferCreatedBy", fields: [createdById], references: [id])
  items       StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id         String   @id @default(uuid())
  transferId String
  materialId String
  quantity   Float
  unit       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@map("stock_transfer_items")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
